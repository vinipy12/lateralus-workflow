{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Approved Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow_name",
    "summary",
    "requirements",
    "assumptions",
    "open_questions",
    "out_of_scope",
    "steps"
  ],
  "properties": {
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_name": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "stepwise",
        "ship"
      ]
    },
    "base_branch": {
      "type": "string",
      "minLength": 1
    },
    "review_path": {
      "type": "string",
      "minLength": 1
    },
    "ship_skill": {
      "type": "string",
      "minLength": 1
    },
    "request_codex_review": {
      "type": "boolean"
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "text"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "out_of_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "goal",
          "requirement_ids",
          "context",
          "planned_updates",
          "planned_creates",
          "constraints",
          "done_when",
          "verify_cmds",
          "commit_message"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "goal": {
            "type": "string",
            "minLength": 1
          },
          "requirement_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "context": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "planned_updates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "planned_creates": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "done_when": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "verify_cmds": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "agents_paths": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "commit_message": {
            "type": "string",
            "minLength": 1
          },
          "justification": {
            "type": "string",
            "minLength": 1
          },
          "files_read_first": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "interfaces_to_preserve": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "avoid_touching": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "verification_targets": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "risk_flags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "blast_radius": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "decision_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "wave": {
            "type": "integer",
            "minimum": 1
          },
          "file_ownership": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "rollback_notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "operational_watchpoints": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
