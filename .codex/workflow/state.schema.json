{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Workflow State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "workflow_name",
    "workflow_status",
    "escalation",
    "mode",
    "plan_path",
    "review_path",
    "ship_skill",
    "current_step_id",
    "base_branch",
    "request_codex_review",
    "uat_artifact_path",
    "metrics_dir",
    "steps"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "workflow_name": {
      "type": "string",
      "minLength": 1
    },
    "workflow_status": {
      "type": "string",
      "enum": [
        "active",
        "execution_escalated",
        "uat_pending",
        "gap_closure_pending",
        "replan_required",
        "ship_pending",
        "complete"
      ]
    },
    "escalation": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "code",
        "summary",
        "blocking_step_id",
        "resume_status",
        "first_triggered_at",
        "last_triggered_at",
        "occurrence_count"
      ],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "verification_missing",
            "verification_failed",
            "ownership_mismatch",
            "agents_update_required",
            "review_required",
            "uat_replan_required",
            "manual_override",
            "unknown_blocker"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "blocking_step_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "resume_status": {
          "type": "string",
          "enum": [
            "active",
            "uat_pending",
            "gap_closure_pending",
            "replan_required",
            "ship_pending",
            "complete"
          ]
        },
        "details": {
          "type": [
            "object",
            "array",
            "null"
          ]
        },
        "first_triggered_at": {
          "type": "string",
          "minLength": 1
        },
        "last_triggered_at": {
          "type": "string",
          "minLength": 1
        },
        "occurrence_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "mode": {
      "type": "string",
      "enum": [
        "stepwise",
        "ship"
      ]
    },
    "plan_path": {
      "type": "string",
      "minLength": 1
    },
    "review_path": {
      "type": "string",
      "minLength": 1
    },
    "ship_skill": {
      "type": "string",
      "minLength": 1
    },
    "current_step_id": {
      "type": "string",
      "minLength": 1
    },
    "base_branch": {
      "type": "string",
      "minLength": 1
    },
    "request_codex_review": {
      "type": "boolean"
    },
    "uat_artifact_path": {
      "type": "string",
      "minLength": 1
    },
    "metrics_dir": {
      "type": "string",
      "minLength": 1
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "goal",
          "context",
          "constraints",
          "done_when",
          "verify_cmds",
          "agents_paths",
          "commit_message",
          "status",
          "review_summary",
          "review_record"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "goal": {
            "type": "string",
            "minLength": 1
          },
          "context": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "done_when": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "verify_cmds": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "agents_paths": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "commit_message": {
            "type": "string",
            "minLength": 1
          },
          "justification": {
            "type": "string",
            "minLength": 1
          },
          "files_read_first": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "interfaces_to_preserve": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "avoid_touching": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "verification_targets": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "risk_flags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "blast_radius": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "decision_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "wave": {
            "type": "integer",
            "minimum": 1
          },
          "file_ownership": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "rollback_notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "operational_watchpoints": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "agents_update_required": {
            "type": "boolean"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "implementing",
              "review_pending",
              "fix_pending",
              "commit_pending",
              "committed",
              "shipped"
            ]
          },
          "review_summary": {
            "type": [
              "string",
              "null"
            ]
          },
          "review_record": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": false,
            "required": [
              "outcome",
              "summary",
              "scope_confirmed",
              "verification_status",
              "verification_note",
              "agents_checked",
              "agents_updated",
              "finding_count",
              "checked_at"
            ],
            "properties": {
              "outcome": {
                "type": "string",
                "enum": [
                  "pending",
                  "passed",
                  "failed"
                ]
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "scope_confirmed": {
                "type": "boolean"
              },
              "verification_status": {
                "type": "string",
                "enum": [
                  "passed",
                  "blocked"
                ]
              },
              "verification_note": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "agents_checked": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "agents_updated": {
                "type": "boolean"
              },
              "finding_count": {
                "type": "integer",
                "minimum": 0
              },
              "checked_at": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
