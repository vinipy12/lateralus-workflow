{
  "plan_id": "example-feature-rollout",
  "workflow_name": "Example feature rollout",
  "summary": "Deliver the example feature as two approval-ready, commit-worthy slices.",
  "mode": "ship",
  "base_branch": "origin/main",
  "request_codex_review": true,
  "requirements": [
    {
      "id": "R1",
