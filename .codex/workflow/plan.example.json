      "planned_creates": [],
      "constraints": [
        "Keep the follow-up scoped to the second slice."
      ],
      "justification": "This lands the second behavior change without reopening the first slice.",
      "files_read_first": [
        "app/example/second_module.py",
        "tests/example/test_second_module.py"
      ],
      "interfaces_to_preserve": [
        "Second example module public behavior contract"
      ],
      "avoid_touching": [
        "app/example/module.py"
      ],
      "verification_targets": [
        "tests/example/test_second_module.py"
